# Test-container configuration for DDBCore's integration tests and the
# docker-compose.testing.yml stack. These are throwaway local test
# credentials — nothing here is a secret.
#
# Both the testcontainers-based `cargo test` runs and the compose stack
# read from this file, so image versions and credentials stay in sync.

# --- PostgreSQL ---
DDBCORE_TEST_PG_TAG=16-alpine
DDBCORE_TEST_PG_DATABASE=postgres
DDBCORE_TEST_PG_USER=postgres
DDBCORE_TEST_PG_PASSWORD=postgres
# Host port used only by docker-compose (testcontainers assigns random ports)
DDBCORE_TEST_PG_HOST_PORT=55432

# --- MariaDB (exercises the MySQL adapter) ---
DDBCORE_TEST_MARIADB_TAG=11.3
DDBCORE_TEST_MARIADB_DATABASE=ddbcore_test
DDBCORE_TEST_MARIADB_ROOT_PASSWORD=ddbcore
DDBCORE_TEST_MARIADB_HOST_PORT=53306
